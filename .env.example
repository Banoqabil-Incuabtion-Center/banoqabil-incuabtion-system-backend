MONGO_URL=mongodb://<username>:<password>@<host-00>:27017,<host-01>:27017,<host-02>:27017/<database>?ssl=true&replicaSet=<replica-set>&authSource=admin&retryWrites=true&w=majority&appName=<app-name>
# If SRV DNS works on your machine, this format is also valid:
# MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority&appName=<app-name>

JWT_SECRET=<replace-with-a-long-random-secret>

# ADMIN_URL=https://admin.example.com
USER_URL=https://frontend.example.com
LOCAL_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

CLOUDINARY_CLOUD_NAME=<cloudinary-cloud-name>
CLOUDINARY_API_KEY=<cloudinary-api-key>
CLOUDINARY_API_SECRET=<cloudinary-api-secret>

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<smtp-user-email>
SMTP_PASS=<smtp-app-password>
